{
  "name": "ai-dungeon-master-recorder",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm --filter frontend check && pnpm test && pnpm build",
    "lint": "eslint .",
    "format": "prettier --write \"apps/**/*.{ts,js,json,css}\" \"services/**/*.{ts,js,json}\" \"scripts/**/*.ts\" \"*.{json,mjs,yml,yaml}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,js,json,css}\" \"services/**/*.{ts,js,json}\" \"scripts/**/*.ts\" \"*.{json,mjs,yml,yaml}\"",
    "typecheck": "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
