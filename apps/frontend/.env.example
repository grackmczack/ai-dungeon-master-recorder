# Frontend environment variables (optional — API is proxied via nginx)
# VITE_API_BASE=/api

# Optional analytics. Leave all three empty until the consent-gated web and server
# containers are published. The serving path comes from the server container's
# "Google Tag Manager: Web Container" client. These values are not secrets.
VITE_GTM_CONTAINER_ID=
VITE_GTM_SERVER_URL=https://analytics.dnd-recorder.de
VITE_GTM_SERVING_PATH=
