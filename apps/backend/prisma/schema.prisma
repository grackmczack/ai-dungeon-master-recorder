generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  passwordHash           String
  displayName            String
  role                   UserRole  @default(DM)
  isActive               Boolean   @default(true)
  sessionVersion         Int       @default(0)
  passwordResetTokenHash String?   @unique
  passwordResetExpiresAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  memberships  GroupMembership[]
  // Keys die dieser Admin an andere DMs verliehen hat
  grantedKeys  AdminApiKeyGrant[] @relation("GrantedBy")
  // Keys die diesem DM von einem Super-Admin verliehen wurden
  receivedKeys AdminApiKeyGrant[] @relation("GrantedTo")
}

enum UserRole {
  SUPER_ADMIN
  DM
}

model AdminApiKeyGrant {
  id           String    @id @default(cuid())
  superAdminId String
  dmId         String
  grantedAt    DateTime  @default(now())
  revokedAt    DateTime?

  superAdmin User @relation("GrantedBy", fields: [superAdminId], references: [id], onDelete: Cascade)
  dm         User @relation("GrantedTo", fields: [dmId], references: [id], onDelete: Cascade)

  @@unique([superAdminId, dmId])
}

model Group {
  id             String   @id @default(cuid())
  name           String
  discordGuildId String?  @unique
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships      GroupMembership[]
  campaigns        Campaign[]
  settings         GroupSettings?
  discordLinkToken DiscordLinkToken?
}

model DiscordLinkToken {
  id        String   @id @default(cuid())
  groupId   String   @unique
  codeHash  String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model DiscordInstallation {
  id             String    @id @default(cuid())
  discordGuildId String    @unique
  guildName      String
  isActive       Boolean   @default(true)
  installedAt    DateTime  @default(now())
  removedAt      DateTime?
  lastSeenAt     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model GroupMembership {
  id                 String    @id @default(cuid())
  // userId ist optional: Mitglieder sind in v1 reine Entitäten ohne eigenen Login.
  // Ein User-Account (userId gesetzt) ist nur für den DM/GM nötig, der sich einloggt.
  userId             String?
  groupId            String
  role               Role      @default(PLAYER)
  // Discord-Handle des realen Spielers (z.B. "grackmczack"). Ein discordName kann
  // in verschiedenen Kampagnen unterschiedliche Charaktere haben — daher liegt
  // die Zuordnung pro Membership, nicht global am User.
  discordName        String?
  // Discord-Anzeigename / Server-Nickname des realen Spielers (z.B. "Rose").
  // discordName ist der eindeutige Username (z.B. "veganrevlady"), discordDisplayName
  // der (nicht eindeutige) Anzeigename. Das Matching zur SpeakerMap läuft über discordName.
  discordDisplayName String?
  characterName      String?
  // Freitext-Rolle innerhalb der Gruppe (z.B. "Tank", "Healer", "Scout") — nicht zu verwechseln mit Role (GM/PLAYER/OBSERVER)
  partyRole          String?
  avatarUrl          String?
  characterSheetUrl  String?
  joinedAt           DateTime  @default(now())
  leftAt             DateTime?
  isPaused           Boolean   @default(false)
  pausedAt           DateTime?
  pauseNote          String?
  notes              String?

  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

enum Role {
  GM
  PLAYER
  OBSERVER
}

model Campaign {
  id                 String   @id @default(cuid())
  groupId            String
  name               String
  description        String?
  setting            String?
  isActive           Boolean  @default(true)
  campaignContext    String?
  // Hintergrundbild fuer das Kampagnen-Dashboard + Detailansicht (Parallax-Effekt beim Scrollen)
  backgroundImageUrl String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  group     Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sessions  Session[]
  npcs      CampaignNPC[]
  quests    CampaignQuest[]
  locations CampaignLocation[]
  threads   CampaignThread[]
  loots     CampaignLoot[]
}

model Session {
  id              String        @id @default(cuid())
  campaignId      String
  discordGuildId  String
  sessionNumber   Int?
  title           String?
  sessionImageUrl String?
  startedAt       DateTime      @default(now())
  stoppedAt       DateTime?
  status          SessionStatus @default(RECORDING)
  activeMemberIds String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  campaign        Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recordings      Recording[]
  transcript      Transcript?
  summary         Summary?
  speakerMaps     SpeakerMap[]
  threadsOpened   CampaignThread[] @relation("ThreadOpenedIn")
  threadsResolved CampaignThread[] @relation("ThreadResolvedIn")
  questsOpened    CampaignQuest[]  @relation("QuestOpenedIn")
  questsResolved  CampaignQuest[]  @relation("QuestResolvedIn")
  npcsFirstSeen   CampaignNPC[]    @relation("NPCFirstSeen")
  npcsLastSeen    CampaignNPC[]    @relation("NPCLastSeen")
}

enum SessionStatus {
  RECORDING
  PROCESSING
  TRANSCRIBING
  SUMMARIZING
  DONE
  FAILED
}

model Recording {
  id              String   @id @default(cuid())
  sessionId       String
  filename        String
  filePath        String
  durationSeconds Float?
  fileSizeBytes   BigInt?
  format          String   @default("mp3")
  createdAt       DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Transcript {
  id        String   @id @default(cuid())
  sessionId String   @unique
  rawJson   Json
  provider  String
  language  String   @default("de")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Summary {
  id                 String   @id @default(cuid())
  sessionId          String   @unique
  narrative          String
  npcs               Json     @default("[]")
  quests             Json     @default("[]")
  loot               Json     @default("[]")
  locations          Json     @default("[]")
  openThreads        Json     @default("[]")
  sessionImagePrompt String?
  model              String
  provider           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SpeakerMap {
  id               String  @id @default(cuid())
  sessionId        String
  discordUserId    String
  discordName      String
  characterName    String?
  playerName       String?
  // Verknüpfung zum anonymen Diarization-Label aus dem Transkript (z.B. "SPEAKER_00").
  // WhisperX liefert nur anonyme Sprecher-Labels, keine echten Discord-Namen —
  // der DM ordnet hier manuell zu, welches Label zu welchem echten Teilnehmer gehört.
  diarizationLabel String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, discordUserId])
  @@unique([sessionId, diarizationLabel])
}

model GroupSettings {
  id                   String  @id @default(cuid())
  groupId              String  @unique
  whisperProvider      String  @default("openai")
  whisperApiKey        String?
  whisperEndpoint      String?
  huggingfaceToken     String?
  replicateApiKey      String?
  imageGenModel        String  @default("black-forest-labs/flux-schnell")
  sessionImageProvider String?
  sessionImageModel    String?
  llmProvider          String  @default("anthropic")
  llmApiKey            String?
  llmModel             String?
  llmEndpoint          String?
  summaryLanguage      String  @default("de")
  postSummaryChannelId String?
  llmSystemPrompt      String?
  llmCampaignContext   String?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// ─── Quest-Wiki ─────────────────────────────────────────────
// Stufe 1: Reine Aggregation aus vorhandenen Session-Summaries.
// Die folgenden Modelle werden später (Stufe 2/3) um manuelle und
// LLM-generierte Einträge erweitert. Für Stufe 1 werden sie per
// Aggregations-Endpoint on-the-fly aus Summary-JSON befüllt.
// ────────────────────────────────────────────────────────────

model CampaignThread {
  id                  String       @id @default(cuid())
  campaignId          String
  campaign            Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  status              ThreadStatus @default(OPEN)
  openedInSessionId   String?
  openedInSession     Session?     @relation("ThreadOpenedIn", fields: [openedInSessionId], references: [id], onDelete: SetNull)
  resolvedInSessionId String?
  resolvedInSession   Session?     @relation("ThreadResolvedIn", fields: [resolvedInSessionId], references: [id], onDelete: SetNull)
  // Verknüpfte Fäden (z.B. ein Faden baut auf einem anderen auf)
  linkedThreadIds     String[]     @default([])
  // Sessions, in denen dieser Faden vorkommt
  sessionIds          String[]     @default([])
  // Quelle: 'aggregated' = automatisch aus Summary extrahiert, 'manual' = DM hat es angelegt
  source              String       @default("aggregated")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([campaignId])
}

model CampaignNPC {
  id                 String    @id @default(cuid())
  campaignId         String
  campaign           Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  firstSeenSessionId String?
  firstSeenSession   Session?  @relation("NPCFirstSeen", fields: [firstSeenSessionId], references: [id], onDelete: SetNull)
  lastSeenSessionId  String?
  lastSeenSession    Session?  @relation("NPCLastSeen", fields: [lastSeenSessionId], references: [id], onDelete: SetNull)
  status             NPCStatus @default(ACTIVE)
  // Sessions, in denen dieser NSC auftauchte
  sessionIds         String[]  @default([])
  source             String    @default("aggregated")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([campaignId, name])
  @@index([campaignId])
}

model CampaignLocation {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sessionIds  String[] @default([])
  source      String   @default("aggregated")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([campaignId, name])
  @@index([campaignId])
}

model CampaignQuest {
  id                  String      @id @default(cuid())
  campaignId          String
  campaign            Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  status              QuestStatus @default(DISCOVERED)
  openedInSessionId   String?
  openedInSession     Session?    @relation("QuestOpenedIn", fields: [openedInSessionId], references: [id], onDelete: SetNull)
  resolvedInSessionId String?
  resolvedInSession   Session?    @relation("QuestResolvedIn", fields: [resolvedInSessionId], references: [id], onDelete: SetNull)
  rewardItems         String[]    @default([])
  sessionIds          String[]    @default([])
  source              String      @default("aggregated")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([campaignId])
}

model CampaignLoot {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // Sessions, in denen diese Beute gefunden wurde
  sessionIds  String[] @default([])
  // Quelle: 'aggregated' = automatisch aus Summary extrahiert, 'manual' = DM hat es angelegt
  source      String   @default("aggregated")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([campaignId])
}

enum ThreadStatus {
  OPEN
  RESOLVED
  ABANDONED
}

enum NPCStatus {
  ACTIVE
  DEAD
  UNKNOWN
  ALLY
  ENEMY
}

enum QuestStatus {
  DISCOVERED
  ACTIVE
  COMPLETED
  FAILED
}
