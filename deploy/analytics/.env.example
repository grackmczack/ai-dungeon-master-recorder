# Resolve the current stable image once and pin the exact digest before deploy:
# docker pull gcr.io/cloud-tagging-10302018/gtm-cloud-image:stable
# docker image inspect --format '{{index .RepoDigests 0}}' gcr.io/cloud-tagging-10302018/gtm-cloud-image:stable
GTM_IMAGE=gcr.io/cloud-tagging-10302018/gtm-cloud-image@sha256:REPLACE_WITH_VERIFIED_DIGEST

# Pin the gateway image as well; never deploy a mutable tag.
NGINX_IMAGE=nginx@sha256:REPLACE_WITH_VERIFIED_DIGEST

# Secret copied from GTM server container -> Admin -> Container Settings ->
# Manually provision tagging server. Never commit the real value.
GTM_CONTAINER_CONFIG=
